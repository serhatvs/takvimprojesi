{
  "name": "agu-kampus-takvimi",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.16.0",
  "engines": {
    "node": ">=24.0.0 <25",
    "pnpm": "11.16.0"
  },
  "scripts": {
    "preinstall": "node scripts/check-node-version.mjs",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "prisma:validate": "pnpm --filter @agu/api prisma:validate",
    "prisma:migrate:dev": "pnpm --filter @agu/api prisma:migrate:dev",
    "prisma:generate": "pnpm --filter @agu/api prisma:generate",
    "seed": "pnpm --filter @agu/api seed"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.0.1",
    "turbo": "^2.10.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0"
  }
}
