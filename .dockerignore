# Keeps the Cloud Build / docker build context small and makes sure nothing
# sensitive or generated ever reaches an image layer. The build context for
# both apps/api/Dockerfile and apps/web/Dockerfile is the monorepo root
# (needed for `turbo prune`), so this file is shared by both builds.

# Version control
**/.git
**/.gitignore

# Secrets / local env files (never bake these into an image)
**/.env
**/.env.*
!**/.env.example

# Dependencies (reinstalled from pnpm-lock.yaml inside the image)
**/node_modules
**/.pnpm-store

# Build caches / generated output (rebuilt inside the image)
**/.turbo
**/.next
**/.next-*
**/dist
**/coverage
**/*.tsbuildinfo
**/generated

# Test / dev artifacts
**/*.log
**/.DS_Store
out-api-verify
out-web-verify

# Docs and misc (not needed at build or runtime)
docs
AGENTS.md
README.md
